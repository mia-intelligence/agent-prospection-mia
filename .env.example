# =============================================
# AGENT PROSPECTION MIA — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps Places API
# Créer sur console.cloud.google.com — activer "Places API"
GOOGLE_MAPS_API_KEY=AIza...

# Apollo.io
# Récupérer sur app.apollo.io > Settings > API
APOLLO_API_KEY=...

# Brevo (SendinBlue)
# Récupérer sur app.brevo.com > SMTP & API > API Keys
BREVO_API_KEY=xkeysib-...

# Airtable
# Récupérer sur airtable.com/create/tokens
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# PhantomBuster (optionnel — pour automatiser les DMs LinkedIn)
PHANTOMBUSTER_API_KEY=
PHANTOMBUSTER_AGENT_ID=

# Configuration expéditeur
MIA_EMAIL=contact@mia-intelligence.com
MIA_NAME=Laetitia Coloré — MIA
CALENDLY_LINK=https://calendly.com/mia-intelligence/diagnostic-express
